PORT=3001
AWS_REGION=ap-northeast-2

# S3 이미지 업로드 (GET /api/upload-url)
# 버킷 이름. Lambda는 IAM Role에 s3:PutObject, s3:GetObject 권한 필요
S3_BUCKET=your-bucket-name

# 트레이너 등록 (POST /api/trainers) - DynamoDB 테이블 이름
TRAINERS_TABLE=trainers

# --- 로컬 Node 백엔드는 사용하지 않음. API는 Lambda + API Gateway 사용. ---
# Lambda: IAM Role로 DynamoDB 접근 (별도 키 불필요)
# 로컬 Node에서 DynamoDB 쓰려면 아래 설정 필요 (현재 미사용)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_ENDPOINT=http://localhost:8000  # DynamoDB Local 사용 시
